# ============================================================================
# VASTRA BACKEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in all required values.
# Required variables are marked [REQUIRED].
# Optional variables have sensible defaults.
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Description: Node.js environment (development, staging, or production)
# Get it from: Set manually based on deployment
# Example format: development
NODE_ENV=development

# Description: Port for backend server to listen on
# Get it from: Set manually (default 4000 for local development)
# Example format: 4000
PORT=4000

# ============================================================================
# DATABASE CONFIGURATION [REQUIRED]
# ============================================================================

# Description: PostgreSQL connection string with connection pooling (for app)
# Get it from: Supabase > Project Settings > Database > Connection String (Pooler)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?pgbouncer=true&sslmode=require
# Security: Use Pooler URL to prevent connection exhaustion
DATABASE_URL=postgresql://user:password@host:5432/database?pgbouncer=true&sslmode=require

# Description: Direct PostgreSQL connection string for migrations (no pooling)
# Get it from: Supabase > Project Settings > Database > Connection String (Session)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require
# Security: Only use for Prisma migrations, not in production app
DIRECT_URL=postgresql://user:password@host:5432/database?sslmode=require

# ============================================================================
# REDIS CONFIGURATION [REQUIRED]
# ============================================================================

# Description: Redis connection URL for caching (outfit cache, weather cache)
# Get it from: Upstash > Console > Database > Copy REDIS_URL
# Format: redis://default:[password]@[host]:[port]
# Features: Used for outfit suggestions (30min), weather data (1hr), quality scores (1hr)
REDIS_URL=redis://default:password@host:6379

# ============================================================================
# JWT AUTHENTICATION [REQUIRED]
# ============================================================================

# Description: Secret key for signing JWT access tokens (7 days validity)
# Get it from: Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Requirements: Minimum 32 characters, keep secret and secure
# Security: Different for each environment
JWT_ACCESS_SECRET=replace_with_random_32_character_string_minimum

# Description: Secret key for signing JWT refresh tokens (30 days validity)
# Get it from: Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Requirements: Minimum 32 characters, different from access secret
# Security: Different for each environment
JWT_REFRESH_SECRET=replace_with_different_random_32_character_string

# Description: JWT access token expiration duration
# Get it from: Set to "7d" (7 days) for standard app tokens
# Format: Node.js ms format (7d, 24h, 3600000ms)
JWT_ACCESS_EXPIRES_IN=7d

# Description: JWT refresh token expiration duration
# Get it from: Set to "30d" (30 days) for refresh tokens
# Format: Node.js ms format (30d, 720h, 2592000000ms)
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# FIREBASE ADMIN SDK [REQUIRED]
# ============================================================================

# Description: Firebase project ID for authentication and Cloud Messaging
# Get it from: Firebase Console > Project Settings > General > Project ID
# Format: lowercase-with-hyphens-12345
# Example: vastra-7f311
FIREBASE_PROJECT_ID=your-firebase-project-id

# Description: Firebase service account email for Admin SDK
# Get it from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key > client_email
# Format: firebase-adminsdk-[code]@[project-id].iam.gserviceaccount.com
# Example: firebase-adminsdk-fbsvc@vastra-7f311.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Description: Firebase service account private key for Admin SDK authentication
# Get it from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key > private_key
# Format: Full PEM-formatted private key (single line with literal \n characters)
# Security: Extremely sensitive - never commit to version control
# Important: Must include -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY----- markers
# Warning: Copy the exact value from Firebase JSON, use literal \n not actual newlines
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ============================================================================
# CLOUDINARY IMAGE HOSTING [REQUIRED]
# ============================================================================

# Description: Cloudinary account cloud name for image uploads
# Get it from: Cloudinary Dashboard > Settings > Cloud Name
# Format: lowercase-alphanumeric
# Example: vastraRoot
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Description: Cloudinary API key for programmatic uploads
# Get it from: Cloudinary Dashboard > Settings > API Keys > API Key
# Format: numeric string
# Example: 249417979931414
CLOUDINARY_API_KEY=your-api-key

# Description: Cloudinary API secret for signing requests
# Get it from: Cloudinary Dashboard > Settings > API Keys > API Secret
# Format: alphanumeric string with special characters
# Security: Extremely sensitive - never commit to version control
# Example: L5cwt_ICyA_ycsAh_0PK0Q4NT3w
CLOUDINARY_API_SECRET=your-api-secret

# ============================================================================
# MISTRAL AI - OUTFIT & ADVICE GENERATION [REQUIRED]
# ============================================================================

# Description: Mistral API key for outfit suggestions and care advice
# Get it from: console.mistral.ai > API Keys > Create API Key
# Format: Starts with "sk-", followed by alphanumeric characters
# Example: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Features: Provides outfit suggestions, care advice, occasion context, wardrobe analysis
# Documentation: https://docs.mistral.ai/
MISTRAL_API_KEY=sk-replace_with_mistral_api_key

# Description: Mistral API base URL (should not change)
# Get it from: Fixed endpoint provided by Mistral
# Format: HTTPS URL
# Default: https://api.mistral.ai/v1
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Description: Mistral model for text generation
# Get it from: Mistral API documentation > Available Models
# Format: Model name with version
# Default: mistral-medium-latest
# Features: Used for outfit suggestions, quality advice, occasion context, wardrobe gap analysis
MISTRAL_MODEL=mistral-medium-latest

# ============================================================================
# NVIDIA NIM - VISION MODEL (Cloth Tagging & Care Label OCR) [REQUIRED]
# ============================================================================

# Description: NVIDIA NIM API key for vision model access (Gemma-3)
# Get it from: build.nvidia.com > API Keys > Create API Key
# Format: Starts with "nvapi-", followed by alphanumeric characters
# Example: nvapi-wN1234567890abcdef1234567890abcdef
# Models: Gemma-3 27B Vision for cloth detection and care label reading
# Documentation: https://docs.nvidia.com/nim/
NVIDIA_GEMMA_API_KEY=nvapi-replace_with_nvidia_api_key

# Description: NVIDIA NIM API base URL (should not change)
# Get it from: Fixed endpoint provided by NVIDIA
# Format: HTTPS URL
# Default: https://integrate.api.nvidia.com/v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Description: NVIDIA vision model for cloth detection and care label OCR
# Get it from: NVIDIA NIM documentation > Available Vision Models
# Format: Model ID with provider
# Default: google/gemma-3-27b-it
# Features: Auto-detect fabric, color, pattern, occasion from photos; Read care labels on garments
NVIDIA_GEMMA_MODEL=google/gemma-3-27b-it

# ============================================================================
# OPENWEATHER API (Optional)
# ============================================================================

# Description: OpenWeather API key for real-time weather data
# Get it from: OpenWeather > API Keys > Create API Key (requires free account)
# Format: Alphanumeric string, typically 32 characters
# Optional: Leave empty to disable weather-aware recommendations
# Features: Current temperature, humidity, condition for outfit suggestions
OPENWEATHER_API_KEY=

# Description: OpenWeather API base URL (should not change)
# Get it from: Fixed endpoint provided by OpenWeather
# Format: HTTPS URL
# Default: https://api.openweathermap.org/data/2.5
# Cache: Weather data cached for 1 hour in Redis
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ============================================================================
# ERROR TRACKING & OBSERVABILITY (Optional)
# ============================================================================

# Description: Sentry DSN for error tracking and monitoring
# Get it from: Sentry > Project Settings > Client Keys (DSN)
# Format: https://[key]@[host]/[project-id]
# Example: https://abc123@sentry.io/123456789
# Optional: Leave empty to disable Sentry error tracking
# Features: Production error monitoring, performance tracking, release tracking
SENTRY_DSN=

# ============================================================================
# CORS & RATE LIMITING
# ============================================================================

# Description: Allowed origin for CORS requests
# Get it from: Your frontend URL or "*" for development only
# Format: https://[domain]:[port]
# Security: Never use "*" in production
# Development: http://localhost:3000
# Production: https://app.vastra.com
CORS_ORIGIN=http://localhost:3000

# Description: Rate limit window duration in milliseconds
# Get it from: Set based on traffic expectations
# Format: milliseconds
# Default: 900000 (15 minutes)
# Example: 60000 = 1 minute, 900000 = 15 minutes, 3600000 = 1 hour
RATE_LIMIT_WINDOW_MS=900000

# Description: Maximum requests allowed per window per IP
# Get it from: Set based on rate limit policy
# Default: 120 requests per 15 minutes (~8 req/min)
# Adjust lower for strict limits, higher for lenient limits
RATE_LIMIT_MAX=120

# ============================================================================
# LOGGING
# ============================================================================

# Description: Winston logging level for console and file output
# Get it from: Set based on environment needs
# Options: error, warn, info, http, verbose, debug, silly
# Development: debug (most verbose)
# Production: info (important events only)
LOG_LEVEL=info

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
# 1. NEVER commit .env to version control (add to .gitignore)
# 2. For production, use secrets management:
#    - AWS Secrets Manager
#    - Heroku Config Vars
#    - Railway Environment Variables
#    - GCP Secret Manager
# 3. Rotate JWT secrets and API keys regularly
# 4. Use different Firebase projects for development and production
# 5. Enable 2FA on all API provider accounts
# 6. Monitor API usage to avoid unexpected bills
# 7. Keep Firebase private key in secure vault, never in code
# 8. Test .env configuration before deploying to production
# ============================================================================
