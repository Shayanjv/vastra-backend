{
  "name": "vastra-backend",
  "version": "1.0.0",
  "description": "Production-ready backend API for Vastra, an Indian AI wardrobe manager app.",
  "private": true,
  "main": "dist/src/app.js",
  "engines": {
    "node": "^20.19 || ^22.12 || >=24.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/src/app.js",
    "postinstall": "npx prisma generate --config prisma/prisma.config.ts",
    "prisma:generate": "npx prisma generate --config prisma/prisma.config.ts",
    "prisma:migrate": "npx prisma migrate deploy --config prisma/prisma.config.ts",
    "prisma:deploy": "npx prisma migrate deploy --config prisma/prisma.config.ts",
    "prisma:studio": "npx prisma studio --config prisma/prisma.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@imgly/background-removal-node": "^1.4.5",
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@sentry/node": "^9.10.0",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
